   44:				        ; --- สเต็ป E: หน่วงเวลา 0.5 วินาที ตามโจทย์สั่ง ---
   45:	  0132	12 01 6D	        CALL    DELAY_500MS
   46:
   47:	  0135	80 E1		        SJMP    MAIN_LOOP       ; วนลูปส่งข้อมูลแบบนี้ไปเรื่อยๆ
   48:
   49:				; ==========================================
   50:				; โปรแกรมย่อย: แปลงค่า 1 Byte เป็นอักษรฐาน 16 (2 ตัว) แล้วส่งออก Serial
   51:				; ==========================================
   52:	  0137			SEND_HEX_BYTE:
   53:	  0137	C0 E0		        PUSH    ACC             ; เก็บค่าดั้งเดิมไว้ก่อน
   54:	  0139	C4		        SWAP    A               ; สลับ 4 บิตบนมาไว้ครึ่งล่าง (เพื่อทำตัวหน้าก่อน)
   55:	  013A	12 01 49	        CALL    NIBBLE_TO_ASCII
   56:	  013D	12 01 63	        CALL    SEND_CHAR       ; ส่งตัวอักษรตัวหน้าออกไป
   57:
   58:	  0140	D0 E0		        POP     ACC             ; ดึงค่าดั้งเดิมกลับมา
   59:	  0142	12 01 49	        CALL    NIBBLE_TO_ASCII ; ทำ 4 บิตล่าง
   60:	  0145	12 01 63	        CALL    SEND_CHAR       ; ส่งตัวอักษรตัวหลังออกไป
   61:	  0148	22		        RET
   62:
   63:	  0149			NIBBLE_TO_ASCII:
   64:	  0149	54 0F		        ANL     A, #0FH         ; ตัดเอาแค่ 4 บิตล่างมาพิจารณา
   65:	  014B	C0 83		        PUSH    DPH             ; เซฟค่า DPTR เดิมเก็บไว้ก่อน
   66:	  014D	C0 82		        PUSH    DPL
   67:	  014F	90 01 88	        MOV     DPTR, #HEX_TABLE
   68:	  0152	93		        MOVC    A, @A+DPTR      ; ไปดึงตัวอักษร '0'-'F' จากตารางด้านล่าง
   69:	  0153	D0 82		        POP     DPL             ; คืนค่า DPTR กลับมา
   70:	  0155	D0 83		        POP     DPH
   71:	  0157	22		        RET
   72:
   73:				; ==========================================
   74:				; โปรแกรมย่อย: ส่งข้อความยาวๆ (String)
   75:				; ==========================================
   76:	  0158			SEND_STRING:
   77:	  0158	E4		        CLR     A
   78:	  0159	93		        MOVC    A, @A+DPTR
   79:	  015A	60 06		        JZ      SEND_STRING_END ; ถ้าดึงข้อมูลมาเจอเลข 00H แปลว่าจบประโยค ให้หยุด
   80:	  015C	12 01 63	        CALL    SEND_CHAR
   81:	  015F	A3		        INC     DPTR
   82:	  0160	80 F6		        SJMP    SEND_STRING
   83:	  0162			SEND_STRING_END:
   84:	  0162	22		        RET
   85:
   86:				; ==========================================
   87:				; โปรแกรมย่อย: ส่งอักขระ 1 ตัว (Char)
   88:				; ==========================================
   89:	  0163			SEND_CHAR:
   90:	  0163	C2 99		        CLR     TI              ; เคลียร์ธงรอส่ง
   91:	  0165	F5 99		        MOV     SBUF, A         ; ยัดข้อมูลลงท่อส่ง
   92:	  0167	30 99 FD	        JNB     TI, $           ; ยืนรอจนกว่าจะส่งเสร็จ (TI เด้งเป็น 1)
   93:	  016A	C2 99		        CLR     TI              ; ส่งเสร็จแล้วเคลียร์ธงทิ้ง
   94:	  016C	22		        RET
   95:
   96:				; ==========================================
   97:				; โปรแกรมย่อย: หน่วงเวลา 500ms (0.5 วินาที)
