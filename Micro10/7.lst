 Line  I  Addr  Code            Source

    1:		N      0000	ORG     0000H
    2:	  0000	02 01 00	        JMP     MAIN
    3:
    4:		N      0100	        ORG     0100H
    5:	  0100			MAIN:
    6:	  0100	75 81 3F	        MOV     SP, #3FH
    7:	  0103	C2 AF		        CLR     EA              ; ปิด Interrupt (ใช้แบบวนลูปเช็คเอา)
    8:
    9:				        ; --- 1. ตั้งค่า Timer และ Counter ---
   10:				        ; TMOD = 0010 0101B (25H)
   11:				        ; -> ครึ่งซ้าย (20H) : ตั้ง Timer 1 เป็น Mode 2 (ใช้สร้าง Baud Rate 9600)
   12:				        ; -> ครึ่งขวา (05H) : ตั้ง Timer 0 เป็น Counter Mode 1 (รับสัญญาณนับจากภายนอกที่ขา P3.4)
   13:	  0105	75 89 25	        MOV     TMOD, #25H
   14:
   15:				        ; --- 2. ตั้งค่า Serial Port (9600 bps @ คริสตัล 11.0592 MHz) ---
   16:	  0108	75 8D FD	        MOV     TH1, #0FDH      ; ค่า TH1 สำหรับ 9600 bps
   17:	  010B	75 98 50	        MOV     SCON, #50H      ; Serial Mode 1, อนุญาตให้รับ-ส่ง (REN=1)
   18:	  010E	D2 8E		        SETB    TR1             ; สตาร์ท Timer 1 ให้ Serial เริ่มทำงาน
   19:
   20:				        ; --- 3. ตั้งค่า Counter 0 (ตัวนับชิ้นงาน) ---
   21:	  0110	75 8C 00	        MOV     TH0, #0         ; เคลียร์ค่านับหลักบนให้เป็น 0
   22:	  0113	75 8A 00	        MOV     TL0, #0         ; เคลียร์ค่านับหลักล่างให้เป็น 0
   23:	  0116	D2 8C		        SETB    TR0             ; สตาร์ท Counter 0 ให้เริ่มรอรับ Pulse ชิ้นงาน
   24:
   25:	  0118			MAIN_LOOP:
   26:				        ; --- สเต็ป A: ส่งข้อความ "Data Count = " ---
   27:	  0118	90 01 7A	        MOV     DPTR, #STR_DATA
   28:	  011B	12 01 58	        CALL    SEND_STRING
   29:
   30:				        ; --- สเต็ป B: ดึงค่านับ (TH0) มาแปลงเป็นตัวหนังสือ 2 ตัวแล้วส่งออก ---
   31:	  011E	E5 8C		        MOV     A, TH0
   32:	  0120	12 01 37	        CALL    SEND_HEX_BYTE
   33:
   34:				        ; --- สเต็ป C: ดึงค่านับ (TL0) มาแปลงเป็นตัวหนังสือ 2 ตัวแล้วส่งออก ---
   35:	  0123	E5 8A		        MOV     A, TL0
   36:	  0125	12 01 37	        CALL    SEND_HEX_BYTE
   37:
   38:				        ; --- สเต็ป D: ส่งคำสั่งขึ้นบรรทัดใหม่ (Enter) ---
   39:	  0128	74 0D		        MOV     A, #0DH         ; รหัส CR (Carriage Return) ให้กลับไปต้นบรรทัด
   40:	  012A	12 01 63	        CALL    SEND_CHAR
   41:	  012D	74 0A		        MOV     A, #0AH         ; รหัส LF (Line Feed) ให้ปัดตกบรรทัดใหม่
   42:	  012F	12 01 63	        CALL    SEND_CHAR
   43:

